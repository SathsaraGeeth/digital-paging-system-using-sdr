- name: epy_block_8_0
  id: epy_block
  parameters:
    _source_code: "from gnuradio import gr\nimport pmt\nfrom collections import deque\n\
      import threading\nimport time\nimport zlib\n\nclass crc_block(gr.basic_block):\n\
      \    \"\"\"\n    CRC Block (PDU-based)\n    ---------------------\n    TX: Prepend\
      \ CRC32 to data payload and forward PDU.\n    RX: Verify CRC32 at start of data;\
      \ strip CRC and forward if valid.\n    \"\"\"\n\n    def __init__(self):\n \
      \       gr.basic_block.__init__(self, name=\"CRC_PDU\", in_sig=[], out_sig=[])\n\
      \n        # Ports\n        self.message_port_register_in(pmt.intern(\"in_tx\"\
      ))\n        self.set_msg_handler(pmt.intern(\"in_tx\"), self.handle_in_tx)\n\
      \        self.message_port_register_in(pmt.intern(\"in_rx\"))\n        self.set_msg_handler(pmt.intern(\"\
      in_rx\"), self.handle_in_rx)\n\n        self.message_port_register_out(pmt.intern(\"\
      out_tx\"))\n        self.message_port_register_out(pmt.intern(\"out_rx\"))\n\
      \n        # Queues\n        self.tx_queue = deque()\n        self.rx_queue =\
      \ deque()\n\n        # Threads\n        self.running = True\n        self.tx_thread\
      \ = threading.Thread(target=self.tx_loop, daemon=True)\n        self.rx_thread\
      \ = threading.Thread(target=self.rx_loop, daemon=True)\n        self.tx_thread.start()\n\
      \        self.rx_thread.start()\n\n    # ---------------- Handlers ----------------\n\
      \    def handle_in_tx(self, pdu):\n        if pmt.is_pair(pdu):\n          \
      \  self.tx_queue.append(pdu)\n\n    def handle_in_rx(self, pdu):\n        if\
      \ pmt.is_pair(pdu):\n            self.rx_queue.append(pdu)\n\n    # ----------------\
      \ TX loop ----------------\n    def tx_loop(self):\n        while self.running:\n\
      \            if self.tx_queue:\n                pdu = self.tx_queue.popleft()\n\
      \                meta = pmt.car(pdu)  # empty\n                data = list(pmt.u8vector_elements(pmt.cdr(pdu)))\n\
      \n                # Compute CRC32 over the entire payload\n                crc_value\
      \ = zlib.crc32(bytes(data)) & 0xFFFFFFFF\n                crc_bytes = [(crc_value\
      \ >> 24) & 0xFF,\n                             (crc_value >> 16) & 0xFF,\n \
      \                            (crc_value >> 8) & 0xFF,\n                    \
      \         crc_value & 0xFF]\n\n                # Prepend CRC to data\n     \
      \           data_with_crc = crc_bytes + data\n                data_pmt = pmt.init_u8vector(len(data_with_crc),\
      \ data_with_crc)\n\n                # Forward PDU (meta empty, data with CRC)\n\
      \                self.message_port_pub(pmt.intern(\"out_tx\"), pmt.cons(pmt.make_dict(),\
      \ data_pmt))\n            else:\n                time.sleep(0.01)\n\n    # ----------------\
      \ RX loop ----------------\n    def rx_loop(self):\n        while self.running:\n\
      \            if self.rx_queue:\n                pdu = self.rx_queue.popleft()\n\
      \                meta = pmt.car(pdu)  # empty\n                data = list(pmt.u8vector_elements(pmt.cdr(pdu)))\n\
      \                if len(data) < 4:\n                    continue  # invalid\
      \ frame\n\n                # Extract CRC and payload\n                recv_crc_bytes\
      \ = data[:4]\n                payload = data[4:]\n                recv_crc =\
      \ (recv_crc_bytes[0] << 24) | (recv_crc_bytes[1] << 16) | \\\n             \
      \              (recv_crc_bytes[2] << 8) | recv_crc_bytes[3]\n\n            \
      \    # Verify CRC\n                computed_crc = zlib.crc32(bytes(payload))\
      \ & 0xFFFFFFFF\n                if recv_crc == computed_crc:\n             \
      \       # CRC OK: forward PDU without CRC\n                    payload_pmt =\
      \ pmt.init_u8vector(len(payload), payload)\n                    self.message_port_pub(pmt.intern(\"\
      out_rx\"), pmt.cons(pmt.make_dict(), payload_pmt))\n                # else:\
      \ silently drop\n            else:\n                time.sleep(0.01)\n\n   \
      \ # ---------------- Stop ----------------\n    def stop(self):\n        self.running\
      \ = False\n        self.tx_thread.join()\n        self.rx_thread.join()\n  \
      \      return True"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: '(''CRC_PDU'', ''crc_block'', [], [(''in_rx'', ''message'', 1), (''in_tx'',
      ''message'', 1)], [(''out_rx'', ''message'', 1), (''out_tx'', ''message'', 1)],
      ''\n    CRC Block (PDU-based)\n    ---------------------\n    TX: Prepend CRC32
      to data payload and forward PDU.\n    RX: Verify CRC32 at start of data; strip
      CRC and forward if valid.\n    '', [])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2424, 512.0]
    rotation: 0
    state: enabled
