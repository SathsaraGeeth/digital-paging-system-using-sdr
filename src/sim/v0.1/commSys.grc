- name: epy_block_2_0
  id: epy_block
  parameters:
    _source_code: "from gnuradio import gr\nimport pmt\nimport threading\nfrom collections\
      \ import deque\nimport time\n\nclass msgQueue(gr.basic_block):\n    \"\"\"\n\
      \    Message Queue Block with Priority Handling (PDU-based)\n    ------------------------------------------------------\n\
      \    Maintains 4 queues:\n        TX: normal, emergency\n        RX: normal,\
      \ emergency\n    Always prioritizes emergency messages.\n\n    PDU format:\n\
      \        meta: empty\n        data (pmt.u8vector):\n            [emergency(1B),\
      \ src_addr(1B), dst_addr(1B), message payload bytes]\n    \"\"\"\n\n    def\
      \ __init__(self):\n        gr.basic_block.__init__(self, name=\"MsgQueue\",\
      \ in_sig=[], out_sig=[])\n\n        # Message ports\n        self.message_port_register_in(pmt.intern(\"\
      in_tx\"))\n        self.set_msg_handler(pmt.intern(\"in_tx\"), self.handle_in_tx)\n\
      \        self.message_port_register_in(pmt.intern(\"in_rx\"))\n        self.set_msg_handler(pmt.intern(\"\
      in_rx\"), self.handle_in_rx)\n\n        self.message_port_register_out(pmt.intern(\"\
      out_tx\"))\n        self.message_port_register_out(pmt.intern(\"out_rx\"))\n\
      \n        # Queues\n        self.tx_emergency = deque()\n        self.tx_normal\
      \ = deque()\n        self.rx_emergency = deque()\n        self.rx_normal = deque()\n\
      \n        # Thread control\n        self.running = True\n        self.tx_thread\
      \ = threading.Thread(target=self.tx_loop, daemon=True)\n        self.rx_thread\
      \ = threading.Thread(target=self.rx_loop, daemon=True)\n        self.tx_thread.start()\n\
      \        self.rx_thread.start()\n\n    # ---------------- Handlers ----------------\n\
      \    def handle_in_tx(self, msg_pmt):\n        if pmt.is_pair(msg_pmt):\n  \
      \          data_pmt = pmt.cdr(msg_pmt)\n            if pmt.is_u8vector(data_pmt)\
      \ and len(pmt.u8vector_elements(data_pmt)) >= 3:\n                # Determine\
      \ emergency from first byte of data\n                emergency_flag = bool(pmt.u8vector_elements(data_pmt)[0])\n\
      \                if emergency_flag:\n                    self.tx_emergency.append(msg_pmt)\n\
      \                else:\n                    self.tx_normal.append(msg_pmt)\n\
      \n    def handle_in_rx(self, msg_pmt):\n        if pmt.is_pair(msg_pmt):\n \
      \           data_pmt = pmt.cdr(msg_pmt)\n            if pmt.is_u8vector(data_pmt)\
      \ and len(pmt.u8vector_elements(data_pmt)) >= 3:\n                emergency_flag\
      \ = bool(pmt.u8vector_elements(data_pmt)[0])\n                if emergency_flag:\n\
      \                    self.rx_emergency.append(msg_pmt)\n                else:\n\
      \                    self.rx_normal.append(msg_pmt)\n\n    # ----------------\
      \ TX Loop ----------------\n    def tx_loop(self):\n        while self.running:\n\
      \            msg = None\n            if self.tx_emergency:\n               \
      \ msg = self.tx_emergency.popleft()\n            elif self.tx_normal:\n    \
      \            msg = self.tx_normal.popleft()\n\n            if msg is not None:\n\
      \                # Pass PDU unchanged (meta empty, data includes headers in\
      \ first 3 bytes)\n                out_pdu = pmt.cons(pmt.make_dict(), pmt.cdr(msg))\n\
      \                self.message_port_pub(pmt.intern(\"out_tx\"), out_pdu)\n  \
      \          else:\n                time.sleep(0.01)\n\n    # ----------------\
      \ RX Loop ----------------\n    def rx_loop(self):\n        while self.running:\n\
      \            msg = None\n            if self.rx_emergency:\n               \
      \ msg = self.rx_emergency.popleft()\n            elif self.rx_normal:\n    \
      \            msg = self.rx_normal.popleft()\n\n            if msg is not None:\n\
      \                out_pdu = pmt.cons(pmt.make_dict(), pmt.cdr(msg))\n       \
      \         self.message_port_pub(pmt.intern(\"out_rx\"), out_pdu)\n         \
      \   else:\n                time.sleep(0.01)\n\n    # ---------------- Stop ----------------\n\
      \    def stop(self):\n        self.running = False\n        self.tx_thread.join()\n\
      \        self.rx_thread.join()\n        return True"
