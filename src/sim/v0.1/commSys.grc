      \                    self.tx_normal.append(msg_pmt)\n\n    def handle_in_rx(self,\
      \ msg_pmt):\n        if pmt.is_pair(msg_pmt):\n            data_pmt = pmt.cdr(msg_pmt)\n\
      \            if pmt.is_u8vector(data_pmt) and len(pmt.u8vector_elements(data_pmt))\
