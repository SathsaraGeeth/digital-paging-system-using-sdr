- name: epy_block_7_0
  id: epy_block
  parameters:
    _source_code: "from gnuradio import gr\nimport pmt\nfrom collections import deque\n\
      import threading\nimport time\n\nclass address_filter_block(gr.basic_block):\n\
      \    \"\"\"\n    Address Filtering Block (PDU-based)\n    -----------------------------------\n\
      \    - TX: Pass-through from upper layer to lower layer.\n    - RX: Forward\
      \ frames to upper layer only if dst_addr matches my_addr.\n    - Frame format\
      \ (PDU):\n        meta: empty\n        data: [msg_id, ack, emergency, src_addr,\
      \ dst_addr, payload bytes (1024B)]\n    \"\"\"\n\n    def __init__(self, my_addr=0):\n\
      \        gr.basic_block.__init__(self, name=\"AddressFilter\", in_sig=[], out_sig=[])\n\
      \n        self.my_addr = my_addr\n\n        # Message ports\n        self.message_port_register_in(pmt.intern(\"\
      in_tx\"))  # upper -> lower\n        self.set_msg_handler(pmt.intern(\"in_tx\"\
      ), self.handle_in_tx)\n\n        self.message_port_register_in(pmt.intern(\"\
      in_rx\"))  # lower -> upper\n        self.set_msg_handler(pmt.intern(\"in_rx\"\
      ), self.handle_in_rx)\n\n        self.message_port_register_out(pmt.intern(\"\
      out_tx\"))\n        self.message_port_register_out(pmt.intern(\"out_rx\"))\n\
      \n        # Queues\n        self.tx_queue = deque()\n        self.rx_queue =\
      \ deque()\n\n        # Threads\n        self.running = True\n        self.tx_thread\
      \ = threading.Thread(target=self.tx_loop, daemon=True)\n        self.rx_thread\
      \ = threading.Thread(target=self.rx_loop, daemon=True)\n        self.tx_thread.start()\n\
      \        self.rx_thread.start()\n\n    # ---------------- Handlers ----------------\n\
      \    def handle_in_tx(self, pdu):\n        if pmt.is_pair(pdu):  # Expecting\
      \ PDU (meta, data)\n            self.tx_queue.append(pdu)\n\n    def handle_in_rx(self,\
      \ pdu):\n        if pmt.is_pair(pdu):  # Expecting PDU (meta, data)\n      \
      \      self.rx_queue.append(pdu)\n\n    # ---------------- TX loop ----------------\n\
      \    def tx_loop(self):\n        while self.running:\n            if self.tx_queue:\n\
      \                pdu = self.tx_queue.popleft()\n                # Pass-through\
      \ to lower layer\n                self.message_port_pub(pmt.intern(\"out_tx\"\
      ), pdu)\n            else:\n                time.sleep(0.01)\n\n    # ----------------\
      \ RX loop ----------------\n    def rx_loop(self):\n        while self.running:\n\
      \            if self.rx_queue:\n                pdu = self.rx_queue.popleft()\n\
      \                data = list(pmt.u8vector_elements(pmt.cdr(pdu)))\n        \
      \        if len(data) < 5:\n                    continue  # invalid frame\n\
      \                dst_addr = data[4]  # dst_addr is 5th byte\n              \
      \  if dst_addr == self.my_addr:\n                    # Forward to upper layer\
      \ (pass PDU as-is)\n                    self.message_port_pub(pmt.intern(\"\
      out_rx\"), pdu)\n                # else: silently drop\n            else:\n\
      \                time.sleep(0.01)\n\n    # ---------------- Stop ----------------\n\
      \    def stop(self):\n        self.running = False\n        self.tx_thread.join()\n\
      \        self.rx_thread.join()\n        return True"
