  parameters:
    _source_code: "#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\nfrom gnuradio\
      \ import gr\nfrom PyQt5 import QtWidgets, QtCore, QtGui\nimport sys\nimport\
      \ pmt\nfrom datetime import datetime\n\nclass WallpaperScrollArea(QtWidgets.QScrollArea):\n\
      \    def __init__(self, parent=None):\n        super().__init__(parent)\n  \
      \      self.setWidgetResizable(True)\n        self.setHorizontalScrollBarPolicy(QtCore.Qt.ScrollBarAlwaysOff)\n\
      \n\nclass _GuiPoster(QtCore.QObject):\n    \"\"\"Helper QObject to post strings\
      \ into the Qt thread safely.\"\"\"\n    sig = QtCore.pyqtSignal(str)  # emits\
      \ text payload\n\n    def __init__(self):\n        super().__init__()\n\n\n\
      class messenger_gui(gr.basic_block):\n    \"\"\"\n    WhatsApp-style Messenger\
      \ GUI (GNU Radio embedded block).\n    - Outgoing messages: published on message\
      \ port \"out\" with address prepended as \"addr:body\"\n    - Feedback port\
      \ \"feedback\": updates delivery timestamp / failed status\n    - Incoming messages:\
      \ received on port \"in_msg\" (same format \"addr:body\") and displayed\n  \
      \    on the left in a different color.\n    \"\"\"\n\n    def __init__(self):\n\
      \        gr.basic_block.__init__(\n            self,\n            name=\"Messeges\"\
      ,\n            in_sig=None,\n            out_sig=None,\n        )\n\n      \
      \  # Message ports\n        self.message_port_register_out(pmt.intern(\"out\"\
      ))    # outgoing messages\n        self.message_port_register_in(pmt.intern(\"\
      feedback\"))# delivery feedback\n        self.message_port_register_in(pmt.intern(\"\
      in_msg\"))  # incoming messages from remote/devices\n\n        # Bind handlers\n\
      \        self.set_msg_handler(pmt.intern(\"feedback\"), self._process_feedback)\n\
      \        self.set_msg_handler(pmt.intern(\"in_msg\"), self._receive_message)\n\
      \n        # Poster used to safely move messages to GUI thread\n        self._poster\
      \ = _GuiPoster()\n        self._poster.sig.connect(self._display_incoming) \
      \ # connect to GUI-thread handler\n\n        # Qt Application\n        self.app\
      \ = QtWidgets.QApplication.instance()\n        if self.app is None:\n      \
      \      self.app = QtWidgets.QApplication(sys.argv)\n\n        # Main window\
      \ with dark theme\n        self.qt_widget = QtWidgets.QWidget()\n        self.qt_widget.setWindowTitle(\"\
      Messenger GUI User 2\")\n        self.qt_widget.resize(680, 600)\n        self.qt_widget.setStyleSheet(\"\
      \"\"\n            QWidget {\n                background-color: #1a1a2e;\n  \
      \              color: #eaeaea;\n            }\n        \"\"\")\n\n        main_layout\
      \ = QtWidgets.QVBoxLayout()\n        main_layout.setContentsMargins(0, 0, 0,\
      \ 0)\n        main_layout.setSpacing(0)\n        self.qt_widget.setLayout(main_layout)\n\
      \n        # Header bar with receiver input\n        header = QtWidgets.QWidget()\n\
      \        header.setStyleSheet(\"\"\"\n            QWidget {\n              \
      \  background: qlineargradient(x1:0, y1:0, x2:1, y2:0,\n                   \
      \ stop:0 #6a11cb, stop:1 #2575fc);\n                border-bottom: 2px solid\
      \ #4a5568;\n            }\n        \"\"\")\n        header.setFixedHeight(70)\n\
      \        header_layout = QtWidgets.QHBoxLayout()\n        header_layout.setContentsMargins(20,\
      \ 10, 20, 10)\n        header.setLayout(header_layout)\n\n        # Receiver\
      \ label and input\n        addr_label = QtWidgets.QLabel(\"To:\")\n        addr_label.setStyleSheet(\"\
      \"\"\n            font-size: 16px;\n            font-weight: bold;\n       \
      \     color: #ffffff;\n            background: transparent;\n        \"\"\"\
      )\n        header_layout.addWidget(addr_label)\n\n        self.addr_box = QtWidgets.QLineEdit()\n\
      \        self.addr_box.setPlaceholderText(\"Enter receiver (e.g., userA=1, userB=2)\"\
      )\n        self.addr_box.setText(\"1\")  # Default receiver\n        self.addr_box.setFixedWidth(300)\n\
      \        self.addr_box.setStyleSheet(\"\"\"\n            QLineEdit {\n     \
      \           background-color: rgba(255, 255, 255, 0.15);\n                border:\
      \ 2px solid rgba(255, 255, 255, 0.3);\n                border-radius: 20px;\n\
      \                padding: 8px 15px;\n                font-size: 14px;\n    \
      \            color: #ffffff;\n            }\n            QLineEdit:focus {\n\
      \                border: 2px solid #00d4ff;\n                background-color:\
      \ rgba(255, 255, 255, 0.25);\n            }\n            QLineEdit::placeholder\
      \ {\n                color: rgba(255, 255, 255, 0.6);\n            }\n     \
      \   \"\"\")\n        header_layout.addWidget(self.addr_box)\n        header_layout.addStretch()\n\
      \n        main_layout.addWidget(header)\n\n        # Scroll area with background\n\
      \        self.scroll_area = WallpaperScrollArea()\n        self.scroll_area.setStyleSheet(\"\
      \"\"\n            QScrollArea {\n                border: none;\n           \
      \     background-color: #16213e;\n            }\n        \"\"\")\n        self.scroll_area.setWidgetResizable(True)\n\
      \        main_layout.addWidget(self.scroll_area)\n\n        # Chat container\
      \ (vertical list of message widgets)\n        self.chat_container = QtWidgets.QWidget()\n\
      \        self.chat_layout = QtWidgets.QVBoxLayout()\n        self.chat_layout.setAlignment(QtCore.Qt.AlignTop)\n\
      \        self.chat_layout.setSpacing(12)\n        self.chat_layout.setContentsMargins(15,\
      \ 15, 15, 15)\n        self.chat_container.setLayout(self.chat_layout)\n   \
      \     self.chat_container.setStyleSheet(\"background: transparent;\")\n    \
      \    self.scroll_area.setWidget(self.chat_container)\n\n        # Input area\
      \ (text entry + send) with modern styling\n        input_container = QtWidgets.QWidget()\n\
      \        input_container.setStyleSheet(\"\"\"\n            QWidget {\n     \
      \           background-color: #0f3460;\n                border-top: 2px solid\
      \ #4a5568;\n            }\n        \"\"\")\n        input_container.setFixedHeight(80)\n\
      \        input_layout = QtWidgets.QHBoxLayout()\n        input_layout.setContentsMargins(15,\
      \ 15, 15, 15)\n        input_container.setLayout(input_layout)\n\n        self.input_box\
      \ = QtWidgets.QLineEdit()\n        self.input_box.setPlaceholderText(\"Type\
      \ your message...\")\n        self.input_box.setMinimumHeight(45)\n        self.input_box.setStyleSheet(\"\
      \"\"\n            QLineEdit {\n                border: 2px solid #4a5568;\n\
      \                border-radius: 22px;\n                padding: 10px 18px;\n\
      \                background-color: #1a1a2e;\n                color: #eaeaea;\n\
      \                font-size: 15px;\n            }\n            QLineEdit:focus\
      \ {\n                border: 2px solid #00d4ff;\n                background-color:\
      \ #252545;\n            }\n            QLineEdit::placeholder {\n          \
      \      color: #6c757d;\n            }\n        \"\"\")\n        \n        self.send_button\
      \ = QtWidgets.QPushButton(\"Send\")\n        self.send_button.setMinimumHeight(45)\n\
      \        self.send_button.setFixedWidth(100)\n        self.send_button.setStyleSheet(\"\
      \"\"\n            QPushButton {\n                background: qlineargradient(x1:0,\
      \ y1:0, x2:1, y2:0,\n                    stop:0 #f093fb, stop:1 #f5576c);\n\
      \                color: white;\n                border: none;\n            \
      \    border-radius: 22px;\n                padding: 10px 20px;\n           \
      \     font-weight: bold;\n                font-size: 15px;\n            }\n\
      \            QPushButton:hover {\n                background: qlineargradient(x1:0,\
      \ y1:0, x2:1, y2:0,\n                    stop:0 #fa709a, stop:1 #fee140);\n\
      \            }\n            QPushButton:pressed {\n                background:\
      \ qlineargradient(x1:0, y1:0, x2:1, y2:0,\n                    stop:0 #d387ab,\
      \ stop:1 #b8255f);\n            }\n        \"\"\")\n        \n        input_layout.addWidget(self.input_box)\n\
      \        input_layout.addWidget(self.send_button)\n        main_layout.addWidget(input_container)\n\
      \n        # Connect GUI signals\n        self.send_button.clicked.connect(self.send_message)\n\
      \        self.input_box.returnPressed.connect(self.send_message)\n\n       \
      \ # Track last sent message timestamp widget\n        self._last_message_timestamp\
      \ = None\n\n        # show window\n        self.qt_widget.show()\n\n    def\
      \ send_message(self):\n        \"\"\"Called from GUI thread when user presses\
      \ Send or Enter.\"\"\"\n        text = self.input_box.text().strip()\n     \
      \   if not text:\n            return\n\n        addr = self.addr_box.text().strip()\n\
      \        if not addr:\n            addr = \"1\"  # Default to 1 if empty\n \
      \           \n        full_msg = f\"{addr}:{text}\"\n\n        # Publish as\
      \ PMT symbol/string on 'out' port\n        try:\n            self.message_port_pub(pmt.intern(\"\
      out\"), pmt.intern(full_msg))\n        except Exception:\n            # fallback\
      \ to generic intern\n            self.message_port_pub(pmt.intern(\"out\"),\
      \ pmt.intern(full_msg))\n\n        # Build outgoing bubble (right side)\n  \
      \      container = QtWidgets.QWidget()\n        container.setStyleSheet(\"background:\
      \ transparent;\")\n        vbox = QtWidgets.QVBoxLayout()\n        vbox.setContentsMargins(0,\
      \ 0, 0, 0)\n        vbox.setSpacing(4)\n\n        # Scrollable area for long\
      \ messages\n        scroll = QtWidgets.QScrollArea()\n        scroll.setWidgetResizable(True)\n\
      \        scroll.setHorizontalScrollBarPolicy(QtCore.Qt.ScrollBarAsNeeded)\n\
      \        scroll.setVerticalScrollBarPolicy(QtCore.Qt.ScrollBarAlwaysOff)\n \
      \       scroll.setFrameShape(QtWidgets.QFrame.NoFrame)\n        scroll.setStyleSheet(\"\
      background: transparent; border: none;\")\n\n        bubble = QtWidgets.QLabel(text)\n\
      \        bubble.setWordWrap(False)\n        bubble.setTextInteractionFlags(QtCore.Qt.TextSelectableByMouse)\n\
      \        bubble.setStyleSheet(\"\"\"\n            QLabel {\n               \
      \ background: qlineargradient(x1:0, y1:0, x2:1, y2:1,\n                    stop:0\
      \ #667eea, stop:1 #764ba2);\n                color: #ffffff;\n             \
      \   border-radius: 18px;\n                padding: 12px 16px;\n            \
      \    font-size: 14px;\n            }\n        \"\"\")\n        \n        # Shadow\
      \ effect\n        effect = QtWidgets.QGraphicsDropShadowEffect()\n        effect.setBlurRadius(10)\n\
      \        effect.setXOffset(0)\n        effect.setYOffset(3)\n        effect.setColor(QtGui.QColor(0,\
      \ 0, 0, 100))\n        bubble.setGraphicsEffect(effect)\n\n        scroll.setWidget(bubble)\n\
      \        scroll.setMinimumWidth(160)\n        scroll.setMaximumWidth(520)\n\n\
      \        # Timestamp pill\n        timestamp = QtWidgets.QLabel(\"Sending...\"\
      )\n        timestamp.setStyleSheet(\"\"\"\n            QLabel {\n          \
      \      background-color: rgba(0, 212, 255, 0.3);\n                color: #00d4ff;\n\
      \                font-size: 10px;\n                border-radius: 10px;\n  \
      \              padding: 3px 8px;\n            }\n        \"\"\")\n        timestamp.setAlignment(QtCore.Qt.AlignRight)\n\
      \        timestamp.setSizePolicy(QtWidgets.QSizePolicy.Fixed, QtWidgets.QSizePolicy.Fixed)\n\
      \n        vbox.addWidget(scroll, alignment=QtCore.Qt.AlignRight)\n        vbox.addWidget(timestamp,\
      \ alignment=QtCore.Qt.AlignRight)\n        container.setLayout(vbox)\n     \
      \   container.setSizePolicy(QtWidgets.QSizePolicy.Expanding, QtWidgets.QSizePolicy.Fixed)\n\
      \n        # Add to chat layout\n        self.chat_layout.addWidget(container,\
      \ alignment=QtCore.Qt.AlignRight)\n\n        # Force layout update and scroll\
      \ to bottom\n        bubble.adjustSize()\n        scroll.adjustSize()\n    \
      \    container.adjustSize()\n        self.chat_container.adjustSize()\n    \
      \    QtWidgets.QApplication.processEvents()\n        QtCore.QTimer.singleShot(20,\
      \ lambda: self.scroll_area.verticalScrollBar().setValue(\n            self.scroll_area.verticalScrollBar().maximum()\n\
      \        ))\n\n        # Clear input and store timestamp widget\n        self.input_box.clear()\n\
      \        self._last_message_timestamp = timestamp\n\n    def _process_feedback(self,\
      \ msg_pmt):\n        \"\"\"\n        Handler for 'feedback' port. Expected feedback\
      \ values:\n          - \"TRUE\" => show delivery time\n          - \"FALSE\"\
      \ => show 'Failed'\n        \"\"\"\n        try:\n            if pmt.is_symbol(msg_pmt)\
      \ or pmt.is_string(msg_pmt):\n                fb = pmt.symbol_to_string(msg_pmt)\n\
      \            else:\n                py = pmt.to_python(msg_pmt)\n          \
      \      fb = str(py)\n        except Exception:\n            fb = \"<unreadable\
      \ feedback>\"\n\n        print(fb)\n        # Update last timestamp widget\n\
      \        if self._last_message_timestamp:\n            if fb == \"TRUE\":\n\
      \                self._last_message_timestamp.setText(datetime.now().strftime(\"\
      %H:%M:%S\"))\n                self._last_message_timestamp.setStyleSheet(\"\"\
      \"\n                    QLabel {\n                        background-color:\
      \ rgba(76, 175, 80, 0.3);\n                        color: #4caf50;\n       \
      \                 font-size: 10px;\n                        border-radius: 10px;\n\
      \                        padding: 3px 8px;\n                    }\n        \
      \        \"\"\")\n            elif fb == \"FALSE\":\n                self._last_message_timestamp.setText(\"\
      Failed\")\n                self._last_message_timestamp.setStyleSheet(\"\"\"\
      \n                    QLabel {\n                        background-color: rgba(244,\
      \ 67, 54, 0.3);\n                        color: #f44336;\n                 \
      \       font-size: 10px;\n                        border-radius: 10px;\n   \
      \                     padding: 3px 8px;\n                    }\n           \
      \     \"\"\")\n\n    def _receive_message(self, msg_pmt):\n        \"\"\"\n\
      \        Handler for 'in_msg' port. Extracts string and posts it to GUI thread.\n\
      \        \"\"\"\n        try:\n            if pmt.is_symbol(msg_pmt) or pmt.is_string(msg_pmt):\n\
      \                s = pmt.symbol_to_string(msg_pmt)\n            else:\n    \
      \            py = pmt.to_python(msg_pmt)\n                s = str(py)\n    \
      \    except Exception:\n            s = \"<unreadable message>\"\n\n       \
      \ # Post to GUI-thread handler\n        try:\n            self._poster.sig.emit(s)\n\
      \        except Exception:\n            try:\n                self._display_incoming(s)\n\
      \            except Exception:\n                print(\"[messenger_gui] failed\
      \ to deliver incoming message to GUI:\", s)\n\n    def _display_incoming(self,\
      \ full_msg):\n        \"\"\"\n        Build incoming bubble (left aligned).\
      \ full_msg expected in \"addr:body\" format.\n        \"\"\"\n        # Split\
      \ \"addr:body\"\n        if \":\" in full_msg:\n            addr, body = full_msg.split(\"\
      :\", 1)\n            display_text = f\"{body}\"\n            header_text = f\"\
      {addr}\"\n        else:\n            display_text = full_msg\n            header_text\
      \ = \"\"\n\n        container = QtWidgets.QWidget()\n        container.setStyleSheet(\"\
      background: transparent;\")\n        vbox = QtWidgets.QVBoxLayout()\n      \
      \  vbox.setContentsMargins(0, 0, 0, 0)\n        vbox.setSpacing(4)\n\n     \
      \   # Small header with sender address\n        if header_text:\n          \
      \  header = QtWidgets.QLabel(header_text)\n            header.setStyleSheet(\"\
      \"\"\n                font-size: 11px;\n                color: #00d4ff;\n  \
      \              background: transparent;\n                font-weight: bold;\n\
      \            \"\"\")\n            header.setAlignment(QtCore.Qt.AlignLeft)\n\
      \            vbox.addWidget(header, alignment=QtCore.Qt.AlignLeft)\n\n     \
      \   scroll = QtWidgets.QScrollArea()\n        scroll.setWidgetResizable(True)\n\
      \        scroll.setHorizontalScrollBarPolicy(QtCore.Qt.ScrollBarAsNeeded)\n\
      \        scroll.setVerticalScrollBarPolicy(QtCore.Qt.ScrollBarAlwaysOff)\n \
      \       scroll.setFrameShape(QtWidgets.QFrame.NoFrame)\n        scroll.setStyleSheet(\"\
      background: transparent; border: none;\")\n\n        bubble = QtWidgets.QLabel(display_text)\n\
      \        bubble.setWordWrap(False)\n        bubble.setTextInteractionFlags(QtCore.Qt.TextSelectableByMouse)\n\
      \        bubble.setStyleSheet(\"\"\"\n            QLabel {\n               \
      \ background: qlineargradient(x1:0, y1:0, x2:1, y2:1,\n                    stop:0\
      \ #2c3e50, stop:1 #34495e);\n                color: #ecf0f1;\n             \
      \   border-radius: 18px;\n                padding: 12px 16px;\n            \
      \    font-size: 14px;\n                border: 1px solid #4a5568;\n        \
      \    }\n        \"\"\")\n\n        scroll.setWidget(bubble)\n        scroll.setMinimumWidth(160)\n\
      \        scroll.setMaximumWidth(520)\n\n        vbox.addWidget(scroll, alignment=QtCore.Qt.AlignLeft)\n\
      \n        container.setLayout(vbox)\n        container.setSizePolicy(QtWidgets.QSizePolicy.Expanding,\
      \ QtWidgets.QSizePolicy.Fixed)\n\n        self.chat_layout.addWidget(container,\
      \ alignment=QtCore.Qt.AlignLeft)\n\n        # Update layout and scroll to bottom\n\
      \        bubble.adjustSize()\n        scroll.adjustSize()\n        container.adjustSize()\n\
      \        self.chat_container.adjustSize()\n        QtWidgets.QApplication.processEvents()\n\
      \        QtCore.QTimer.singleShot(20, lambda: self.scroll_area.verticalScrollBar().setValue(\n\
      \            self.scroll_area.verticalScrollBar().maximum()\n        ))\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: '(''Messeges'', ''messenger_gui'', [], [(''feedback'', ''message'',
      1), (''in_msg'', ''message'', 1)], [(''out'', ''message'', 1)], ''\n    WhatsApp-style
      Messenger GUI (GNU Radio embedded block).\n    - Outgoing messages: published
      on message port "out" with address prepended as "addr:body"\n    - Feedback
      port "feedback": updates delivery timestamp / failed status\n    - Incoming
      messages: received on port "in_msg" (same format "addr:body") and displayed\n      on
      the left in a different color.\n    '', [])'
